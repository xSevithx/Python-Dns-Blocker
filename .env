# ──────────────────────────────────────────────
#  DNS Blocker Configuration
# ──────────────────────────────────────────────

# Upstream DNS server for forwarding non-blocked queries
UPSTREAM_DNS=8.8.8.8

# Comma-separated domain keywords to block (matched per label, case-insensitive)
BLACKLIST=youtube,youtubekids,youtubei

# Comma-separated IPs that bypass ALL blocking (your devices)
WHITELIST=192.168.1.2,192.168.1.3

# ──────────────────────────────────────────────
#  FULL SHUTOFF — all internet is killed
#  (e.g. bedtime: 1 AM to 8 AM)
#  Set both to the same value to disable.
# ──────────────────────────────────────────────
SHUTOFF_START=00:00
SHUTOFF_END=00:00

# ──────────────────────────────────────────────
#  BLACKLIST ENFORCEMENT — blocked domains are enforced
#  (e.g. during the day: 8 AM to 11 PM)
#  Outside this window the blacklist is NOT enforced,
#  so kids get unrestricted access as a reward.
#  Set both to the same value to enforce 24/7.
# ──────────────────────────────────────────────
ENFORCE_START=08:00
ENFORCE_END=20:00
